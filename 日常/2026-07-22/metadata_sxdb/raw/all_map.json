"<!doctype html><html lang=\"en\"><head><meta charset=\"UTF-8\"/><meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\"/><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/><title></title><script src=\"/lightbox-resource/vendor/appConfig.js\"></script><script src=\"/lightbox-resource/vendor/polyfill.min.js\"></script><script>// 该事件是核心\n            window.addEventListener(\"storage\", function (event) {\n                if (event.key == \"getSessionStorage\") {\n                    // 已存在的标签页会收到这个事件\n                    localStorage.setItem(\n                        \"_up_qjt_csrf_\",\n                        JSON.stringify(sessionStorage)\n                    );\n                    localStorage.removeItem(\"_up_qjt_csrf_\");\n                } else if (\n                    event.key == \"_up_qjt_csrf_\" &&\n                    !sessionStorage.length\n                ) {\n                    // 新开启的标签页会收到这个事件\n                    var data = JSON.parse(event.newValue),\n                        value;\n                    for (key in data) {\n                        sessionStorage.setItem(key, data[key]);\n                    }\n                } else if (event.key === \"_sync_qjt_csrf_\") {\n                    // 重置密码或登出重新登录需要同步其他页面的session\n                    sessionStorage.setItem(\"_csrf_\", event.newValue);\n                }\n            });\n\n            if (!sessionStorage.length) {\n                // 这个调用能触发目标事件，从而达到共享数据的目的\n                localStorage.setItem(\"getSessionStorage\", Date.now());\n            }</script><link href=\"/lightbox-resource/app.ec25049a.css\" rel=\"stylesheet\"></head><body><div id=\"main-root\" class=\"mainapp\"></div><script>function push(subapp) {\n                history.pushState(null, subapp, subapp);\n            }</script><script src=\"/lightbox-resource/vendor/lightbox_v2_dll.js\"></script><script defer=\"defer\" src=\"/lightbox-resource/app.ec25049a.js\"></script></body></html>"